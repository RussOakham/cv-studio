    "@typescript/native-preview": "7.0.0-dev.20260320.1",
    "@vitejs/plugin-react": "^6.0.1",
    "markdownlint-cli2": "^0.21.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  },
  "packageManager": "pnpm@10.27.0"
