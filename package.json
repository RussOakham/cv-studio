{
  "name": "cv-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "oxlint . --deny-warnings && markdownlint-cli2",
    "lint:md": "markdownlint-cli2",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "pnpm run format:check && pnpm run lint && pnpm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@convex-dev/better-auth": "^0.11.2",
